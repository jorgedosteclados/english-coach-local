<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>English Coach Local</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <main class="container">
    <section class="hero hero-with-mascot">
      <div>
        <p class="mascot-kicker">Mini Beagle Coach</p>
        <h1>English Coach Local</h1>
        <p>Practice English for customer support, conversations, and professional messages.</p>
      </div>
      <img
        src="/images/mini-beagle-mascot.png"
        alt="Mini beagle mascot"
        class="mascot-img"
      />
    </section>

    <section class="stats">
      <div class="stat-card">
        <span class="icon">F</span>
        <h2><%= progress.streak_days %></h2>
        <p>day streak</p>
      </div>

      <div class="stat-card">
        <span class="icon">XP</span>
        <h2><%= progress.total_xp %></h2>
        <p>Total XP</p>
      </div>

      <div class="stat-card">
        <span class="icon">L</span>
        <h2><%= progress.lessons_completed %></h2>
        <p>Lessons completed</p>
      </div>
    </section>

    <section class="path-preview">
      <div>
        <p class="unit-label">Your next step</p>
        <h2>Customer Support English Path</h2>
        <p>Follow short lessons, writing missions, and feedback from your mini beagle coach.</p>
      </div>
      <a href="/units" class="primary-link">Continue Learning</a>
    </section>

    <section class="menu">
      <a href="/units" class="menu-card blue">
        <span>1</span>
        <div>
          <h3>Learning Path</h3>
          <p>Follow your Duolingo-style journey</p>
        </div>
      </a>

      <a href="/lesson" class="menu-card blue">
        <span>L</span>
        <div>
          <h3>Daily Lesson</h3>
          <p>Learn useful professional phrases</p>
        </div>
      </a>

      <a href="/writing" class="menu-card green">
        <span>W</span>
        <div>
          <h3>Writing Missions</h3>
          <p>Practice professional messages and emails.</p>
        </div>
      </a>

      <a href="/correct" class="menu-card purple">
        <span>C</span>
        <div>
          <h3>Correct My English</h3>
          <p>Get AI feedback on your writing</p>
        </div>
      </a>

      <a href="/history" class="menu-card teal">
        <span>H</span>
        <div>
          <h3>History</h3>
          <p>Review your previous corrections</p>
        </div>
      </a>
    </section>
  </main>
</body>
</html>

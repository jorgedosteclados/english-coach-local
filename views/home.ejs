<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>English Coach Local</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="coach-page">
  <div class="coach-layout">
    <aside class="coach-nav">
      <a href="/" class="coach-logo">
        <img src="/images/mini-beagle-mascot.png" alt="" />
        <span>English<br />Coach</span>
      </a>

      <nav aria-label="Main navigation">
        <a href="/" class="active"><span>1</span>Learn</a>
        <a href="/mistakes"><span>M</span>Mistakes<% if (dueReviewCount > 0) { %><b class="coach-nav-count"><%= dueReviewCount %></b><% } %></a>
        <a href="/writing"><span>W</span>Writing</a>
        <a href="/conversation"><span>C</span>Conversation</a>
        <a href="/voice-call"><span>V</span>Voice Call</a>
        <a href="/local-ai"><span>AI</span>Local AI</a>
        <a href="/reading?unit=25"><span>R</span>Reading</a>
        <a href="/library"><span>B</span>Library</a>
        <a href="/progress"><span>P</span>Progress</a>
        <a href="/placement"><span>L</span>Level test</a>
        <a href="/history"><span>H</span>History</a>
      </nav>
    </aside>

    <main class="coach-main">
      <header class="coach-mobile-header">
        <div><span>F</span><strong><%= progress.streak_days %></strong><small>streak</small></div>
        <div><span>XP</span><strong><%= progress.total_xp %></strong><small>earned</small></div>
        <div><span>A</span><strong><%= progress.lessons_completed %></strong><small>activities</small></div>
      </header>

      <section class="coach-unit-banner">
        <div>
          <p>Phase <%= pathState.currentSection ? pathState.currentSection.id : 1 %> of 4</p>
          <h1><%= pathState.currentSection ? pathState.currentSection.title : 'Professional Support English' %></h1>
          <span><%= pathState.completedCount %> of <%= pathState.totalCount %> units completed</span>
        </div>
        <a href="/review">Quick review</a>
      </section>

      <section class="coach-path" aria-label="Learning path">
        <div class="coach-path-title">
          <span></span>
          <p>Build confidence one step at a time</p>
          <span></span>
        </div>

        <% pathState.units.forEach((unit, index) => { %>
          <% if (index === 0 || pathState.units[index - 1].sectionId !== unit.sectionId) { %>
            <div class="coach-phase-divider">
              <span>Phase <%= unit.sectionId %></span>
              <strong><%= unit.sectionTitle %></strong>
              <small><%= unit.sectionDescription %></small>
            </div>
          <% } %>
          <div
            class="coach-step step-<%= ['left', 'center', 'right'][index % 3] %> <%= unit.isCheckpoint ? 'checkpoint' : '' %> <%= unit.isCompleted ? 'completed' : '' %> <%= unit.isPlacementSkipped ? 'placement-skipped' : '' %> <%= unit.isLocked ? 'locked' : 'available' %>"
            <% if (!unit.isLocked && unit.href) { %>role="button" tabindex="0"<% } %>
          >
            <span class="coach-step-node">
              <%= unit.isCompleted ? '✓' : unit.isPlacementSkipped ? 'S' : unit.isLocked ? 'L' : unit.isCheckpoint ? 'C' : unit.unit_order %>
            </span>
            <strong><%= unit.title %></strong>
            <small>
              <%= unit.isCompleted ? 'Practice again' : unit.isPlacementSkipped ? 'Skipped by level check' : unit.isLocked ? 'Complete the previous step' : 'Start this step' %>
            </small>
            <% if (!unit.isLocked && unit.href) { %>
              <span class="coach-step-detail" aria-hidden="true">
                <b><%= unit.title %></b>
                <em><%= unit.description %></em>
                <a href="<%= unit.href %>"><%= unit.isCompleted ? 'Practice again +5 XP' : unit.isCheckpoint ? 'Start checkpoint' : 'Start lesson +10 XP' %></a>
              </span>
            <% } %>
          </div>

          <% if (index === 1) { %>
            <img
              src="/images/mini-beagle-mascot.png"
              alt="Mini beagle coach"
              class="coach-path-mascot"
            />
          <% } %>
        <% }) %>

        <a href="/review" class="coach-review-node">
          <span>R</span>
          <strong>Daily Review</strong>
          <small>Visual, listening, and speaking cards</small>
        </a>
      </section>
    </main>

    <aside class="coach-progress-panel">
      <section class="coach-top-stats" aria-label="Your progress">
        <div><strong><%= progress.streak_days %></strong><span>day streak</span></div>
        <div><strong><%= progress.total_xp %></strong><span>total XP</span></div>
      </section>

      <section class="coach-side-card coach-daily-card">
        <p class="coach-side-label">Today's goal</p>
        <h2>Keep the momentum</h2>
        <p>Complete one short activity today.</p>
        <div class="coach-goal-track"><span style="width: <%= progress.lessons_completed > 0 ? 100 : 0 %>%"></span></div>
        <a href="/lesson">Practice now</a>
      </section>

      <section class="coach-side-card coach-level-card">
        <p class="coach-side-label">Personalize your path</p>
        <h2>Check your English level</h2>
        <p>Take a short A1–B2 diagnostic and see your recommended phase.</p>
        <a href="/placement">Start level test</a>
      </section>

      <% const unlockedAchievements = achievements.filter((achievement) => achievement.unlocked); %>
      <section class="coach-side-card">
        <div class="coach-side-heading">
          <div>
            <p class="coach-side-label">Achievements</p>
            <h2>Your badges</h2>
          </div>
          <strong><%= unlockedAchievements.length %>/<%= achievements.length %></strong>
        </div>
        <div class="coach-side-badges">
          <% unlockedAchievements.slice(0, 3).forEach((achievement) => { %>
            <span><b>✓</b><%= achievement.title %></span>
          <% }) %>
        </div>
      </section>

      <section class="coach-side-card coach-tools-card">
        <p class="coach-side-label">Quick practice</p>
        <a href="/mistakes"><span>M</span><div><strong>Review mistakes</strong><small><%= dueReviewCount > 0 ? `${dueReviewCount} review${dueReviewCount === 1 ? '' : 's'} due` : 'No reviews due' %></small></div></a>
        <a href="/speaking"><span>S</span><div><strong>Speaking</strong><small>Pronunciation practice</small></div></a>
        <a href="/voice-call"><span>V</span><div><strong>Voice call</strong><small>Local AI customer simulation</small></div></a>
        <a href="/local-ai"><span>AI</span><div><strong>Local AI chat</strong><small>Talk with Ollama</small></div></a>
        <a href="/correct?mode=call"><span>F</span><div><strong>Call phrases</strong><small>Fix real technical call lines</small></div></a>
        <a href="/reading?unit=25"><span>R</span><div><strong>Trail reading</strong><small>Read with audio and word help</small></div></a>
        <a href="/library"><span>B</span><div><strong>Book library</strong><small>Import full texts</small></div></a>
        <a href="/question-bank"><span>Q</span><div><strong>Question bank</strong><small>Content coverage</small></div></a>
        <a href="/correct"><span>C</span><div><strong>Correct my English</strong><small>Get AI feedback</small></div></a>
      </section>
    </aside>
  </div>

  <nav class="coach-bottom-nav" aria-label="Mobile navigation">
    <a href="/" class="active"><span>1</span>Learn</a>
    <a href="/mistakes"><span>M</span>Mistakes</a>
    <a href="/writing"><span>W</span>Write</a>
    <a href="/voice-call"><span>V</span>Call</a>
    <a href="/local-ai"><span>AI</span>AI</a>
  </nav>
  <script src="/js/soundManager.js"></script>
  <script src="/js/home.js"></script>
</body>
</html>

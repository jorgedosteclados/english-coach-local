<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Support English Lesson</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="lesson-page">
  <main class="lesson-shell">
    <header class="lesson-topbar">
      <a href="/" class="lesson-close" aria-label="Back to learning path">×</a>
      <div class="lesson-progress-wrap">
        <div class="lesson-progress-track"><span id="lessonProgressBar"></span></div>
        <p class="lesson-progress">Question 1 of 5</p>
      </div>
      <div class="lesson-xp"><strong id="lessonXpValue">0</strong><span>XP</span></div>
    </header>

    <section class="lesson-heading">
      <div>
        <p><%= isCheckpoint ? 'Phase checkpoint' : lessonName %></p>
        <h1><%= isCheckpoint ? lessonName : 'Choose the best response' %></h1>
      </div>
      <label class="lesson-category-control <%= isCheckpoint ? 'hidden' : '' %>" for="lessonCategory">
        <span>Practice focus</span>
        <select id="lessonCategory">
          <% lessonCategories.forEach((category) => { %>
            <option value="<%= category.id %>"><%= category.label %></option>
          <% }) %>
        </select>
      </label>
    </section>

    <section class="lesson-exercise">
      <div class="lesson-score-row">
        <div id="scoreDisplay" class="score-display"></div>
      </div>

      <div class="lesson-prompt">
        <span id="lessonTitle">How do you say:</span>
        <p class="question-text">Loading your first question...</p>
      </div>

      <div class="options" aria-label="Answer options"></div>

      <div id="lessonFeedback" class="feedback-box hidden" role="status"></div>

      <div class="lesson-actions">
        <button id="confirmAnswerBtn" class="hidden">Check answer</button>
        <button id="nextQuestionBtn" class="hidden">Continue</button>
        <button id="continueHomeBtn" class="continue-home-btn hidden">Back to learning path</button>
        <button id="restartLessonBtn" class="secondary-btn hidden">Practice again</button>
      </div>
    </section>
  </main>

  <script src="/js/lesson.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Learning Path</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <main class="container">
    <a href="/" class="back-link">Back to Home</a>

    <section class="hero hero-with-mascot compact-mascot">
      <div>
        <p class="mascot-kicker">Mini Beagle Coach</p>
        <h1>Learning Path</h1>
        <p>Build professional English step by step for customer conversations.</p>
      </div>
      <img
        src="/images/mini-beagle-mascot.png"
        alt="Mini beagle mascot"
        class="mascot-img"
      />
    </section>

    <section class="path-summary">
      <div>
        <p class="unit-label">Path progress</p>
        <h2><%= pathState.completedCount %>/<%= pathState.totalCount %> units completed</h2>
      </div>
      <div class="path-progress">
        <div class="path-progress-label">
          <span><%= pathState.progressPercent %>% complete</span>
          <% if (pathState.nextUnit) { %>
            <span>Next: <%= pathState.nextUnit.title %></span>
          <% } %>
        </div>
        <div class="path-progress-track">
          <div style="width: <%= pathState.progressPercent %>%"></div>
        </div>
      </div>
    </section>

    <section class="path">
      <% if (!units || units.length === 0) { %>
        <section class="card">
          <p>The learning path could not be loaded.</p>
        </section>
      <% } %>

      <% units.forEach((unit) => { %>
        <article class="unit-card <%= unit.isCompleted ? 'completed' : '' %> <%= unit.isLocked ? 'locked' : 'active' %>">
          <div class="unit-number"><%= unit.isCompleted ? '✓' : unit.unit_order %></div>
          <div>
            <p class="unit-label">
              <%= unit.isCompleted ? 'Completed' : unit.isLocked ? 'Locked' : `Unit ${unit.unit_order}` %>
            </p>
            <h2><%= unit.title %></h2>
            <p><%= unit.description %></p>
            <div class="unit-meta">
              <span><%= unit.completedCount %> completions</span>
              <% if (unit.lastCompletedAt) { %>
                <span>Last practiced <%= new Date(unit.lastCompletedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></span>
              <% } else { %>
                <span>Not practiced yet</span>
              <% } %>
            </div>

            <% if (unit.isLocked || !unit.href) { %>
              <span class="unit-action disabled">Locked</span>
            <% } else { %>
              <a href="<%= unit.href %>" class="unit-action">
                <%= unit.isCompleted ? 'Practice Again' : 'Start' %>
              </a>
            <% } %>
          </div>
        </article>
      <% }) %>
    </section>
  </main>
</body>
</html>

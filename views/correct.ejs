<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Correct My English</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <main class="container">
    <a href="/" class="back-link">Back to Home</a>

    <section class="hero hero-with-mascot compact-mascot">
      <div>
        <p class="mascot-kicker" id="correctionKicker">Mini Beagle Coach</p>
        <h1 id="correctionTitle">Correct My English</h1>
        <p id="correctionIntro">Write a sentence in English and get feedback.</p>
      </div>
      <img
        src="/images/mini-beagle-mascot.png"
        alt="Mini beagle mascot"
        class="mascot-img"
      />
    </section>

    <section id="correctForm" class="card">
      <div class="correction-mode-tabs" aria-label="Correction mode">
        <button type="button" class="correction-mode-tab active" data-mode="general">General</button>
        <button type="button" class="correction-mode-tab" data-mode="call">Technical call</button>
      </div>

      <label for="text" id="correctionTextLabel">Your sentence</label>
      <textarea id="text" placeholder="Example: I have doubt about this case."></textarea>

      <button id="correctBtn">Correct</button>
    </section>

    <section id="result" class="result hidden">
      <h2>AI Feedback</h2>
      <div id="resultContent"></div>
    </section>
  </main>

  <script src="/js/soundManager.js"></script>
  <script src="/js/feedbackRenderer.js"></script>
  <script src="/js/correct.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>History</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <main class="container">
    <a href="/" class="back-link">Back to Home</a>

    <section class="hero hero-with-mascot compact-mascot">
      <div>
        <p class="mascot-kicker">Mini Beagle Coach</p>
        <h1>History</h1>
        <p>Review, search, and practice your previous corrections.</p>
      </div>
      <img
        src="/images/mini-beagle-mascot.png"
        alt="Mini beagle mascot"
        class="mascot-img"
      />
    </section>

    <section class="history-tools">
      <label for="historySearch">Search history</label>
      <input id="historySearch" type="search" placeholder="Search by phrase or feedback" />

      <div class="history-filters" aria-label="History filters">
        <button type="button" class="history-filter active" data-filter="all">All</button>
        <button type="button" class="history-filter" data-filter="today">Today</button>
        <button type="button" class="history-filter" data-filter="week">This week</button>
      </div>
    </section>

    <section id="historyList" class="history-list"></section>

    <section id="historyEmpty" class="card hidden">
      <p>No corrections found.</p>
    </section>
  </main>

  <script id="historyData" type="application/json"><%- JSON.stringify(corrections || []).replace(/</g, "\\u003c") %></script>
  <script src="/js/feedbackRenderer.js"></script>
  <script src="/js/history.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Writing Mission</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <main class="container">
    <a href="/" class="back-link">Back to Home</a>

    <section class="hero hero-with-mascot compact-mascot">
      <div>
        <p class="mascot-kicker">Mini Beagle Coach</p>
        <h1><%= mission.title %></h1>
        <p>Practice professional English for real work situations.</p>
      </div>
      <img
        src="/images/mini-beagle-mascot.png"
        alt="Mini beagle mascot"
        class="mascot-img"
      />
    </section>

    <section class="card mission-card">
      <p class="mission-label">Scenario</p>
      <p><%= mission.scenario %></p>

      <p class="mission-label">Task</p>
      <p><%= mission.task %></p>
    </section>

    <section
      id="writingForm"
      class="card"
      data-mission-id="<%= mission.id %>"
      data-unit-id="<%= mission.unit_id %>"
      data-xp-reward="<%= mission.xp_reward %>"
    >
      <label for="writingText">Your message</label>
      <textarea id="writingText" placeholder="<%= mission.placeholder %>"></textarea>

      <button id="checkWritingBtn">Check My Writing</button>
    </section>

    <section id="writingResult" class="result hidden">
      <h2>AI Feedback</h2>
      <div id="writingResultContent"></div>
    </section>
  </main>

  <script src="/js/soundManager.js"></script>
  <script src="/js/feedbackRenderer.js"></script>
  <script src="/js/writing.js"></script>
</body>
</html>
